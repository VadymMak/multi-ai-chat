{
  "expo": {
    "name": "Multi-AI Chat",
    "slug": "multi-ai-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8bbf4823-4070-4584-a572-c9c42f8f2e31",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vadymmak.multiaichat",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Multi-AI Chat uses your microphone for voice messages.",
        "NSPhotoLibraryUsageDescription": "Multi-AI Chat accesses your photos to send images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.vadymmak.multiaichat",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "vadymmak",
    "plugins": [
      "expo-localization",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Multi-AI Chat accesses your photos to send images.",
          "cameraPermission": "Multi-AI Chat uses your camera to take photos."
        }
      ],
      "expo-audio",
      "@react-native-community/datetimepicker",
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "8bbf4823-4070-4584-a572-c9c42f8f2e31"
      }
    }
  }
}
