{
  "expo": {
    "name": "Multi-AI Chat",
    "slug": "multi-ai-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vadymmak.multiaichat",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Multi-AI Chat uses your microphone for voice messages."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.vadymmak.multiaichat",
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "vadymmak",
    "plugins": [
      "expo-localization",
      "expo-font"
    ]
  }
}
