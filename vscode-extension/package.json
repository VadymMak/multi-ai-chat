{
  "name": "smartcontext-brain",
  "displayName": "SmartContext Brain",
  "description": "Silent background service — reports diagnostics to the project brain",
  "version": "0.2.0",
  "publisher": "smartcontext",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "SmartContext Brain",
      "properties": {
        "smartcontext.apiUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL of the SmartContext backend (e.g. https://multi-ai-chat-production.up.railway.app/api)"
        },
        "smartcontext.apiToken": {
          "type": "string",
          "default": "",
          "description": "Bearer token for authentication"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.110.0",
    "typescript": "^5.9.3"
  }
}
